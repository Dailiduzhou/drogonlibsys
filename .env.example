# Docker Compose ports
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
BACKEND_PORT=8080
FRONTEND_PORT=8081

# PostgreSQL container
POSTGRES_DB=libsys
POSTGRES_USER=libsys
POSTGRES_PASSWORD=libsys

# MinIO container
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Backend runtime config
LIBSYS_CONFIG_PATH=config/config.docker.json
LIBSYS_JWT_SECRET=change-me-in-production
LIBSYS_JWT_ISSUER=drogonlibsys
LIBSYS_JWT_ACCESS_TTL_SECONDS=900
LIBSYS_JWT_REFRESH_TTL_SECONDS=604800
LIBSYS_REDIS_HOST=redis
LIBSYS_REDIS_PORT=6379
LIBSYS_REDIS_PASSWORD=
LIBSYS_MINIO_ENDPOINT=minio:9000
LIBSYS_MINIO_PUBLIC_ENDPOINT=localhost:9000
LIBSYS_MINIO_ACCESS_KEY=minioadmin
LIBSYS_MINIO_SECRET_KEY=minioadmin
LIBSYS_MINIO_BUCKET=libsys-covers
LIBSYS_MINIO_REGION=us-east-1
LIBSYS_MINIO_SECURE=false
LIBSYS_MINIO_PUBLIC_SECURE=false
